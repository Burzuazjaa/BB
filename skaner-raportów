    async function startScan() {
        if (scanning) {
            return;
        }

        settings = readSettings();
        saveSettings(settings);

        if (
            !settings.scanAF &&
            !settings.scanReports
        ) {
            setStatus(
                'Zaznacz pobieranie z AF albo ze stron raportów.',
                true
            );

            return;
        }

        scanning = true;
        stopRequested = false;
        currentResults = [];

        setButtonsForScan(true);
        setProgress(0);
        clearDisplayedResults();

        try {
            const reportMap = new Map();

            if (settings.scanAF) {
                await collectAllFarmAssistantPages(
                    reportMap
                );
            }

            if (
                settings.scanReports &&
                !stopRequested &&
                reportMap.size < settings.maxReports
            ) {
                await collectAllReportPages(
                    reportMap
                );
            }

            if (stopRequested) {
                throw new Error(
                    'Skanowanie zostało zatrzymane.'
                );
            }

            const reportLinks = Array
                .from(reportMap.values())
                .slice(
                    0,
                    settings.maxReports
                );

            if (!reportLinks.length) {
                throw new Error(
                    'Nie znaleziono żadnych linków do raportów.'
                );
            }

            setStatus(
                `Zebrano ${reportLinks.length} unikalnych raportów. Czytam ich zawartość…`
            );

            const parsed = await processReports(
                reportLinks
            );

            if (stopRequested) {
                throw new Error(
                    'Skanowanie zostało zatrzymane.'
                );
            }

            currentResults = prepareResults(parsed);

            saveResults(currentResults);
            renderResults(currentResults);
            renderSummary(currentResults);

            setProgress(100);

            setStatus(
                `Gotowe. Sprawdzono ${reportLinks.length} raportów. ` +
                `Znaleziono ${currentResults.length} wiosek barbarzyńskich.`
            );
        } catch (error) {
            console.error(
                '[Skaner barbarzyńców]',
                error
            );

            setStatus(
                error?.message ||
                'Wystąpił nieznany błąd.',
                true
            );
        } finally {
            scanning = false;
            setButtonsForScan(false);
        }
    }

    function stopScan() {
        stopRequested = true;

        setStatus(
            'Zatrzymywanie skanowania…'
        );
    }

    async function collectAllFarmAssistantPages(
        reportMap
    ) {
        let page = 0;
        let emptyPages = 0;

        while (
            !stopRequested &&
            reportMap.size < settings.maxReports
        ) {
            setStatus(
                `AF: pobieram stronę ${page + 1}. ` +
                `Raporty: ${reportMap.size}/${settings.maxReports}.`
            );

            const url = createFarmAssistantUrl(page);
            const html = await fetchHtml(url);
            const doc = parseHtml(html);

            const reportLinks =
                extractReportLinks(doc);

            let added = 0;

            for (const report of reportLinks) {
                if (
                    reportMap.size >=
                    settings.maxReports
                ) {
                    break;
                }

                if (!reportMap.has(report.id)) {
                    reportMap.set(
                        report.id,
                        report
                    );

                    added++;
                }
            }

            setCollectionProgress(
                reportMap.size
            );

            if (
                reportLinks.length === 0 ||
                added === 0
            ) {
                emptyPages++;
            } else {
                emptyPages = 0;
            }

            const nextPage = findNextPage(
                doc,
                page
            );

            if (emptyPages >= 2) {
                break;
            }

            if (nextPage === null) {
                if (reportLinks.length === 0) {
                    break;
                }

                page++;
            } else {
                page = nextPage;
            }

            await sleep(settings.delay);
        }
    }

    async function collectAllReportPages(
        reportMap
    ) {
        let page = 0;
        let emptyPages = 0;

        while (
            !stopRequested &&
            reportMap.size < settings.maxReports
        ) {
            setStatus(
                `Raporty: pobieram stronę ${page + 1}. ` +
                `Raporty: ${reportMap.size}/${settings.maxReports}.`
            );

            const url = createReportsUrl(page);
            const html = await fetchHtml(url);
            const doc = parseHtml(html);

            const reportLinks =
                extractReportLinks(doc);

            let added = 0;

            for (const report of reportLinks) {
                if (
                    reportMap.size >=
                    settings.maxReports
                ) {
                    break;
                }

                if (!reportMap.has(report.id)) {
                    reportMap.set(
                        report.id,
                        report
                    );

                    added++;
                }
            }

            setCollectionProgress(
                reportMap.size
            );

            if (
                reportLinks.length === 0 ||
                added === 0
            ) {
                emptyPages++;
            } else {
                emptyPages = 0;
            }

            if (emptyPages >= 2) {
                break;
            }

            const nextPage = findNextPage(
                doc,
                page
            );

            if (nextPage === null) {
                if (reportLinks.length === 0) {
                    break;
                }

                page++;
            } else {
                page = nextPage;
            }

            await sleep(settings.delay);
        }
    }

    function createFarmAssistantUrl(page) {
        const url = new URL(
            '/game.php',
            location.origin
        );

        const villageId =
            getCurrentVillageId();

        if (villageId) {
            url.searchParams.set(
                'village',
                villageId
            );
        }

        url.searchParams.set(
            'screen',
            'am_farm'
        );

        url.searchParams.set(
            'page',
            String(page)
        );

        return url.href;
    }

    function createReportsUrl(page) {
        const url = new URL(
            '/game.php',
            location.origin
        );

        const villageId =
            getCurrentVillageId();

        if (villageId) {
            url.searchParams.set(
                'village',
                villageId
            );
        }

        url.searchParams.set(
            'screen',
            'report'
        );

        url.searchParams.set(
            'mode',
            'all'
        );

        url.searchParams.set(
            'page',
            String(page)
        );

        return url.href;
    }

    function getCurrentVillageId() {
        if (
            typeof game_data !== 'undefined' &&
            game_data?.village?.id
        ) {
            return String(
                game_data.village.id
            );
        }

        return (
            new URLSearchParams(
                location.search
            ).get('village') ||
            ''
        );
    }

    function findNextPage(
        doc,
        currentPage
    ) {
        const pages = [];

        const links = doc.querySelectorAll(
            'a[href*="page="]'
        );

        for (const link of links) {
            const href =
                link.getAttribute('href');

            if (!href) {
                continue;
            }

            try {
                const url = new URL(
                    href,
                    location.origin
                );

                const page = Number(
                    url.searchParams.get('page')
                );

                if (
                    Number.isInteger(page) &&
                    page > currentPage
                ) {
                    pages.push(page);
                }
            } catch {
                // Pominięcie nieprawidłowego odnośnika.
            }
        }

        if (!pages.length) {
            return null;
        }

        pages.sort(
            (a, b) => a - b
        );

        return pages[0];
    }

    function extractReportLinks(doc) {
        const reports = new Map();

        const links = doc.querySelectorAll(
            'a[href*="screen=report"][href*="view="], ' +
            'a[href*="view="][href*="report"]'
        );

        for (const link of links) {
            const href =
                link.getAttribute('href');

            if (!href) {
                continue;
            }

            let url;

            try {
                url = new URL(
                    href,
                    location.origin
                );
            } catch {
                continue;
            }

            const id =
                url.searchParams.get('view');

            if