    function startWatcher() {
        injectStyles();
        tryMountPanel();

        setInterval(() => {
            const urlChanged = lastKnownUrl !== location.href;

            if (urlChanged) {
                lastKnownUrl = location.href;
            }

            if (isSupportedScreen()) {
                tryMountPanel();
            } else {
                removePanel();
            }
        }, 1000);

        const observer = new MutationObserver(() => {
            if (isSupportedScreen()) {
                tryMountPanel();
            }
        });

        observer.observe(document.documentElement, {
            childList: true,
            subtree: true
        });
    }

    function getCurrentScreen() {
        const urlScreen = new URLSearchParams(
            location.search
        ).get('screen');

        if (urlScreen) {
            return urlScreen;
        }

        if (
            typeof game_data !== 'undefined' &&
            game_data &&
            game_data.screen
        ) {
            return String(game_data.screen);
        }

        return '';
    }

    function isSupportedScreen() {
        const screen = getCurrentScreen();

        return screen === 'report' || screen === 'am_farm';
    }

    function removePanel() {
        const panel = document.getElementById(PANEL_ID);

        if (panel) {
            panel.remove();
        }
    }

    function tryMountPanel() {
        if (!isSupportedScreen()) {
            return;
        }

        const existing = document.getElementById(PANEL_ID);

        if (
            existing &&
            document.body.contains(existing)
        ) {
            return;
        }

        const target = findDockTarget();

        if (!target) {
            console.warn(
                '[Skaner barbarzyńców] Nie znaleziono miejsca do zadokowania panelu.'
            );

            return;
        }

        createPanel(target);
    }

    function findDockTarget() {
        const selectors = [
            '#content_value',
            '#contentContainer',
            '#content',
            '.maincell',
            '#mobileContent',
            '#mobileContentContainer'
        ];

        for (const selector of selectors) {
            const element = document.querySelector(selector);

            if (element) {
                return element;
            }
        }

        const mainTable = document.querySelector(
            'table.main, table.vis, #content_value > table'
        );

        if (mainTable?.parentElement) {
            return mainTable.parentElement;
        }

        return document.body || null;
    }

